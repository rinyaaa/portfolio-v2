---
import Base from "../../layouts/Base.astro";
import PostList from "../../components/PostList";
import { getPublishedPosts } from "../../lib/microcms";
import styles from "./post.module.scss";

const posts = await getPublishedPosts();
const allGenres = [...new Set(posts.flatMap((post) => post.genres))].sort();
---

<Base title="Post — nenex">
  <section class={styles.section}>
    {
      posts.length === 0 ? (
        <p class={styles.empty}>まだ記事がありません。</p>
      ) : (
        <PostList client:visible posts={posts} genres={allGenres} />
      )
    }
  </section>
</Base>
